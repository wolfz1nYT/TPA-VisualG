algoritmo "COMPARAR 2 NUMEROS"
// Disciplina   : [TPA] 
// Roberto Carlos 

var
nn:inteiro
nm:inteiro

inicio

escreva("Escreva o primeiro número ")
leia(nn)
escreva("Escreva o segundo número ")
leia(nm)
se (nn > nm) entao
     escreva(nn, " é maior que ",nm  )
     senao
     escreva(nm, " é maior que ",nn  )
fimse
fimalgoritmo